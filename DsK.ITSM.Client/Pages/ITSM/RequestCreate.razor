@page "/ITSM/RequestCreate"

<h3><NavLink href="/">My Requests</NavLink> > Create Request</h3>

@if (!_loaded)
{
    <h3>Loading...</h3>
    <MudProgressLinear Color="Color.Primary" Striped="true" Size="Size.Large" Value="75" Class="my-7" />
}
else
{
    <EditForm Model="model" OnValidSubmit="Create">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <MudCard Class="mb-2">
            <MudCardContent>
                <MudAutocomplete T="string" Label="Requested By" @bind-Value="model.RequestedBy" On
                SearchFunc="@SearchRequestedByList"
                             CoerceText="true" CoerceValue="true" MaxItems=null />
                <MudTextField Label="Summary" @bind-Value="model.Summary"
                          For="@(()=>model.Summary)">
                </MudTextField>
                <MudTextField Label="Description" @bind-Value="model.Description"
                          For="@(()=>model.Description)">
                </MudTextField>

                <ITSystemsDropdown @bind-Value="itsystemDto" />
                <CategoriesDropdown @bind-Value="categoryDto" />
                <PriorityDropdown @bind-Value="priorityDto" />
            </MudCardContent>
        </MudCard>

        <div class="row">
            <div class="col-md-12 text-right">
                <button type="submit" class="btn btn-success">Create</button>
            </div>
        </div>
    </EditForm>
}